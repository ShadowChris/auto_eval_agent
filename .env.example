# ===== OpenAI 兼容代理（当前 models.yaml / judges.yaml 使用）=====
# LiteLLM Virtual Key 通常以 sk- 开头
PROXY_API_KEY=

# ===== 火山引擎豆包（竞品 + 可能当裁判）=====
# 控制台 https://console.volcengine.com/ark 创建接入点(endpoint)，拿到 API Key 与 endpoint id
ARK_API_KEY=
# 豆包 endpoint id，形如 ep-2025xxxx-xxxxx
DOUBAO_ENDPOINT_ID=

# ===== 待评测的自研 agent（若对外是 OpenAI 兼容接口）=====
MY_AGENT_BASE_URL=http://localhost:8000/v1
MY_AGENT_API_KEY=
MY_AGENT_MODEL=default

# ===== 其他竞品 / 裁判模型（复用你已有的 key）=====
GEMINI_API_KEY=
KIMI_API_KEY=

# ===== 裁判联网检索：三选一 =====
TAVILY_API_KEY=
SERPAPI_API_KEY=
BING_API_KEY=

# ===== 语义相似度 embedding（可选；不填则退化到字符/词重叠相似度）=====
OPENAI_API_KEY=

# ===== 评测日志输出 =====
AUTO_EVAL_JUDGE_TRACE="runs/judge_calls.jsonl"

# ===== 实时中文调用链日志（按日期和 50MB 大小滚动，默认永久保留）=====
AUTO_EVAL_CHAIN_LOG_ENABLED=true
AUTO_EVAL_CHAIN_LOG_DIR="logs"
AUTO_EVAL_CHAIN_LOG_MAX_BYTES=52428800
# 默认不把 pytest 中故意构造的超时/断流写入正式日志；排查测试时可临时开启
AUTO_EVAL_CHAIN_LOG_TESTS=false

# ===== 操作类 JSONL 批量导入（可选）=====
# 相对 video_path 默认以项目根目录为基准；需要读取项目外视频时，在此加入允许目录。
# macOS/Linux 多目录用冒号分隔，Windows 用分号分隔。
OPERATION_VIDEO_ROOTS=
